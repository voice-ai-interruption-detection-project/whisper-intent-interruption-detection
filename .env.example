# Local environment template.
# Copy this file to .env and fill in local-only values. Do not commit .env.

# Required for real LLM action policy runs.
OPENAI_API_KEY=

# Optional OpenAI action judge settings.
OPENAI_ACTION_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com
OPENAI_ACTION_TIMEOUT_S=30

# Optional TTS fixture generation settings.
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral
OPENAI_TTS_TIMEOUT_S=60

# Optional audio / embedding defaults.
WHISPER_MODEL=medium
SBERT_MODEL=distiluse-base-multilingual-cased-v2
VAD_THRESHOLD=0.5
